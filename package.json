{
  "name": "bc-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently --names API,WEB --prefix-colors cyan,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "test": "node --test tests/pos-unit.mjs",
    "test:pos:smoke": "node --test tests/pos-smoke.mjs",
    "test:pos:roles": "node tests/pos-roles.mjs",
    "start": "npm run start --workspace=server",
    "migrate": "npm run migrate --workspace=server",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "pdf-to-printer": "^5.8.0",
    "qrcode": "^1.5.4"
  }
}

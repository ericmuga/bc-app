{
  "name": "bc-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev":      "concurrently --names API,WEB --prefix-colors cyan,green \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build":    "npm run build --workspace=client",
    "start":    "npm run start --workspace=server",
    "migrate":  "npm run migrate --workspace=server",
    "seed":     "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

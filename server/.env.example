# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=8h

# SQL Server – connection pool (shared across companies)
DB_HOST=172.16.10.8
DB_PORT=1433
DB_USER=reporter
DB_PASSWORD="p3u!~XuEdx?u2kK"
DB_ENCRYPT=false
DB_TRUST_CERT=true

# Pool settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_ACQUIRE_TIMEOUT=60000

# Default company (used when X-Company-ID header is absent in dev)
DEFAULT_COMPANY=FCL1

# Business Central webhook secret (optional HMAC validation)
BC_WEBHOOK_SECRET=your-bc-webhook-secret

# ── Active Directory / LDAP ──────────────────────────────────────────────────
# Leave blank to disable AD login entirely.

# LDAP URL of your domain controller
# Use ldap:// for port 389, ldaps:// for port 636 (TLS)
AD_URL=ldap://100.100.2.22:389

# Base DN to search for users
AD_BASE_DN=DC=farmerschoice,DC=com

# Domain suffix appended when user types only their short name
AD_DOMAIN=farmerschoice.local

# Service account used to search the directory (read-only is enough)
AD_SERVICE_DN=CN=svc-bc,OU=bc2022,DC=farmerschoice,DC=com
AD_SERVICE_PASS="alV2n).#ej>9"

# Optional: members of this group get role='admin', everyone else gets role='user'
# Leave blank to make all AD users role='user' by default
AD_ADMIN_GROUP=CN=BC-Admins,OU=Groups,DC=farmerschoice,DC=local

# Set to 'false' ONLY in dev with self-signed certificates — never in production
AD_TLS_REJECT_UNAUTHORIZED=true
